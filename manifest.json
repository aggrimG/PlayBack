{
  "manifest_version": 3,
  "name": "PlayBack+",
  "version": "1.3",
  "description": "Web video playback speed controller",
  "permissions": [
    "storage",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}