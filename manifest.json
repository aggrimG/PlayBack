{
  "manifest_version": 3,
  "name": "Set PlayBack",
  "version": "1.0",
  "description": "Automatically forces all web videos to play at your preferred speed.",
  "permissions": [
    "storage"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}